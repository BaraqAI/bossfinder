# ─── LLM Provider (choose one or both) ───────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Model to use for agents (e.g. gpt-4o, claude-opus-4-7, claude-sonnet-4-6)
CREW_LLM_MODEL=gpt-4o

# ─── Web Search ───────────────────────────────────────────────────────────────
# SerpAPI – https://serpapi.com  (Google, Bing, DuckDuckGo results)
SERPAPI_API_KEY=

# Tavily – https://tavily.com  (AI-optimised web search, great for RAG/agents)
TAVILY_API_KEY=tvly-...

# ─── X / Twitter ──────────────────────────────────────────────────────────────
# Twitter API v2 – https://developer.twitter.com
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ─── Email & Contact Discovery ────────────────────────────────────────────────
# Hunter.io – https://hunter.io  (domain search, company enrichment, email finder)
# Free: 25 searches/month  |  Starter: $34/month
HUNTER_API_KEY=

# Apollo.io – https://www.apollo.io  (executive search + per-person email reveal)
APOLLO_API_KEY=

# Snov.io – https://snov.io  (domain search + per-person email finder, 3rd source)
# Get client_id + client_secret from https://app.snov.io/api-setting
# Free: 50 credits/month  |  Starter: $29/month
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# ─── GitHub ───────────────────────────────────────────────────────────────────
# GitHub Personal Access Token – https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# ─── News & Press ─────────────────────────────────────────────────────────────
# NewsAPI – https://newsapi.org
NEWS_API_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
